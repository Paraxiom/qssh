# Rust
/target
**/*.rs.bk
# Cargo.lock is tracked: qssh ships binaries, so reproducible builds
# (cargo install --locked, Homebrew formula) need the locked dep graph.

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Keys and certificates
*.key
*.pem
*.pub
id_qssh*
!*.pub.example

# Logs
*.log

# Config files with secrets
config.toml
!example-config.toml

# Test artifacts
test_*.sh
temp_*

# Build artifacts
*.so
*.dylib
*.dll

# Lean 4 build artifacts
lean/.lake/
